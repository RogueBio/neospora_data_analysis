##Load file

Neospora <- read.csv("Data analysis/Original File/adgg_questionnaire_test_all_+redonePCR_20221230.csv")

## Fix placenta burry issue

Neospora %<>%
  mutate(
    placentaf = ifelse(
      placenta == 'burry',
      'bury',
      placenta
    )
  )
Neospora$placentaf


## Make placenta binary

Neospora %<>%
  mutate(
    placebin = case_when(
      Neospora$placentaf == 'feed_other' ~ "Remain",
      Neospora$placentaf == 'bury' ~ "Remain",
      Neospora$placentaf == 'leave' ~ "Remain",
      Neospora$placentaf == 'throw' ~ "Destroy",
      Neospora$placentaf == 'burn' ~ "Destroy",
      TRUE ~ NA_character_
    )
  )
Neospora$placebin

## Make age discrete
boxplot(Neospora$animalage)


Neospora %<>%
  mutate(
    Animalagef = ifelse(
      Neospora$animalage < 6,
      "0-6",
      "> 6"
    )
  )

Neospora$Animalagef

## Make calf number discrete

Neospora %<>%
  mutate(
    Calfnof = case_when(
      Neospora$calfnumber >= 1 & Neospora$calfnumber <= 1 ~ "0-1",
      Neospora$calfnumber >= 2 & Neospora$calfnumber <= 3 ~ "1-3",
      Neospora$calfnumber >= 4 & Neospora$calfnumber <= 6 ~ "3-6",
      Neospora$calfnumber > 6 ~ ">6",
      TRUE ~ NA_character_
    )
  )

Neospora$Calfnof

## Make calf number binary

Neospora %<>%
  mutate(
    Calfnbin = case_when(
      Neospora$calfnumber >= 1 & Neospora$calfnumber <= 2 ~ "0-2",
      Neospora$calfnumber > 2 ~ ">2",
      TRUE ~ NA_character_
    )
  )

Neospora$Calfnbin


